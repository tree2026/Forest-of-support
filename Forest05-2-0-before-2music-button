function shareEntry(entryIndex, sharePoemOnly = false) {
    const entry = myTree.journals[entryIndex];
    if (!entry) return;
    
    let shareText = '';
    
    if (sharePoemOnly && entry.poem) {
        // Share only the poem
        shareText = `${entry.poem}\n\n${entry.sage || ''}\n\n#ForestOfSupport #HealLikeATree`;
    } else if (entry.type === 'canopy') {
        // Share canopy entry
        shareText = `🌤️ ${entry.principle || entry.title}\n\n${entry.text}\n\n${entry.offering || ''}\n\n#ForestOfSupport #CanopyWisdom`;
    } else if (entry.poem) {
        // Share journal entry with poem
        shareText = `${entry.text}\n\n${entry.poem}\n\n${entry.sage || ''}\n\n#ForestOfSupport #HealLikeATree`;
    } else {
        // Share regular journal entry
        shareText = `${entry.text}\n\n#ForestOfSupport #TreeJournal`;
    }
    
    // Try Web Share API
    if (navigator.share) {
        navigator.share({
            title: 'Forest of Support',
            text: shareText,
            url: window.location.href
        }).catch(err => {
            // 1.9999999 FIX: share entry function before {else{ . Only copy if error is NOT AbortError (user cancellation)
            if (err.name !== 'AbortError' && err.name !== 'CancelError') {
                console.log('Share failed:', err);
                copyToClipboard(shareText);
            } else {
                console.log('Share cancelled by user');
            }
        });//1.9 end
    } else {
        copyToClipboard(shareText);
    }
}

